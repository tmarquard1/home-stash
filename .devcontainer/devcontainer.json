{
	"name": "Home Stash Ansible",
	"image": "mcr.microsoft.com/devcontainers/python:3.12",
	
	// "features": {
	// 	
	// },

	"postCreateCommand": "pip3 install -r requirements.txt && ansible-galaxy collection install community.general ansible.posix",

	"customizations": {
		"vscode": {
			"extensions": [
				"redhat.ansible",
				"redhat.vscode-yaml",
				"github.vscode-github-actions"
			],
			"settings": {
				"ansible.python.interpreterPath": "/usr/local/bin/python"
			}
		}
	},

	"remoteUser": "vscode"
}
