# Immich environment file — managed by Ansible, do not edit manually.
# See ansible/roles/immich/defaults/main.yml for variable definitions.

# ----- Upload / library storage -----
UPLOAD_LOCATION={{ immich_upload_location }}

# ----- Database -----
DB_DATABASE_NAME={{ immich_db_name }}
DB_USERNAME={{ immich_db_username }}
DB_PASSWORD={{ immich_db_password }}

# ----- Immich version -----
IMMICH_VERSION={{ immich_version }}

# ----- Timezone -----
TZ={{ immich_timezone }}
