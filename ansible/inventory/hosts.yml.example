# Inventory template — copy to hosts.yml and fill in your Pi's details.
# hosts.yml is git-ignored so credentials never end up in source control.
all:
  hosts:
    homeserver:
      ansible_host: 192.168.1.100   # Replace with your Pi's IP address
      ansible_user: pi              # Username set during OS imaging
      # ansible_ssh_private_key_file: ~/.ssh/id_rsa   # Uncomment if using key auth
      # ansible_become_password: ""                   # Only needed for sudo password prompt
  vars:
    ansible_python_interpreter: /usr/bin/python3
